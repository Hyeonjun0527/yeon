# Web-only secrets
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yeon
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# ── OpenAI API ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# 녹음 AI 대화 / 멘토링 요약 (텍스트 생성)
# 권장: gpt-4.1-mini (비용 효율), gpt-4.1 (고품질), gpt-5.4-medium (최고급)
OPENAI_AI_CHAT_MODEL=gpt-4.1-mini

# 파일 가져오기 - 스프레드시트 분석 (엑셀 → 수강생 추출)
# 설정 안 하면 OPENAI_AI_CHAT_MODEL 사용
# 권장: gpt-4.1-mini (저렴 + 텍스트 정확도 우수)
OPENAI_AI_IMPORT_MODEL=gpt-4.1-mini

# 파일 가져오기 - 이미지 분석 (이미지 → 수강생 추출, Vision 지원 모델 필수)
# 설정 안 하면 OPENAI_AI_IMPORT_MODEL → OPENAI_AI_CHAT_MODEL 순으로 폴백
# 권장: gpt-4.1-nano (가장 저렴, Vision 지원)
OPENAI_AI_VISION_MODEL=gpt-4.1-nano

# 녹음 전사 (Whisper 계열)
# 권장: gpt-4o-transcribe-diarize (화자 분리 포함)
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize

# 전사 실패 시 폴백 모델 (쉼표 구분, 순서대로 시도)
OPENAI_TRANSCRIPTION_FALLBACK_MODELS=gpt-4o-transcribe
# ────────────────────────────────────────────────────────────────────────────

# Cloudflare R2 (음성 파일 저장)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

COUNSELING_RECORDS_WORK_DIR=

# Google Sheets 연동 (서비스 계정 JSON을 한 줄로)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Microsoft OneDrive 연동
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Google Search Console 도메인 소유권 확인
GOOGLE_SITE_VERIFICATION=

# Public values exposed to the browser
NEXT_PUBLIC_APP_URL=http://localhost:3000
